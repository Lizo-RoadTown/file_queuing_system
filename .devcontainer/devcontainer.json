{
    "name": "epi-sde Review Environment",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/conda/envs/epi-sde/bin/python",
                "jupyter.notebookFileRoot": "${workspaceFolder}/curation-dev/notebooks"
            }
        }
    }
}
