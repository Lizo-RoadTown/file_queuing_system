{
    "name": "epi-sde Review Environment",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "CODESPACES": "${localEnv:CODESPACES}"
        }
    },
    "postCreateCommand": "conda run -n epi-sde python -c 'import numpy; print(\"Environment ready\")'",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/conda/envs/epi-sde/bin/python",
                "jupyter.notebookFileRoot": "${workspaceFolder}/curation-dev/notebooks"
            }
        }
    }
}
